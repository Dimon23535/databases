from cryptography.hazmat.primitives.asymmetric import rsa, padding
from cryptography.hazmat.primitives import hashes
# Генерация ключей
priv = rsa.generate_private_key(public_exponent=65537, key_size=2048)
pub = priv.public_key()
# Данные		
msg = b"Hello"
# Шифрование открытым ключом
enc = pub.encrypt(msg, padding.OAEP(mgf=padding.MGF1(hashes.SHA256()), algorithm=hashes.SHA256(), label=None))
# Расшифровка закрытым ключом
dec = priv.decrypt(enc, padding.OAEP(mgf=padding.MGF1(hashes.SHA256()), algorithm=hashes.SHA256(), label=None))
print("Исходное:", msg)
print("Расшифрованное:", dec)
